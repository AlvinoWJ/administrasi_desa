CREATE TABLE surat (
    nomor_surat VARCHAR(50) PRIMARY KEY,
    nama VARCHAR(100) NOT NULL,
    nik VARCHAR(20) NOT NULL,
    tempat_tanggal_lahir VARCHAR(50) NOT NULL,
    alamat VARCHAR(255) NOT NULL,
    desa VARCHAR(100),
    kecamatan VARCHAR(100),
    kabupaten VARCHAR(100),
    jenis_surat VARCHAR(50) NOT NULL
);

CREATE TABLE surat_menikah (
    nomor_surat VARCHAR(50) PRIMARY KEY,
    jenis_kelamin VARCHAR(20) NOT NULL,
    agama VARCHAR(50) NOT NULL,
    status VARCHAR(50) NOT NULL,
    pekerjaan VARCHAR(100) NOT NULL,
    kewarganegaraan VARCHAR(50) NOT NULL,
    nama_pasangan VARCHAR(100) NOT NULL,
    kewarganegaraan_pasangan VARCHAR(50) NOT NULL,
    FOREIGN KEY (nomor_surat) REFERENCES surat(nomor_surat) ON DELETE CASCADE
);
